function _openFilterButtonTooltip =
		() =>
		VAR _page = SELECTEDVALUE ( 'Report pages'[Page] )
		VAR _flag = _isFiltersAppliedFlag ()
		VAR _text =
		    SWITCH (
		        TRUE (),
		        _flag = 0, [Filters are not applied text],
		        _flag = 1, [Filters are applied text],
		        BLANK ()
		    )
		VAR _result = _text
		RETURN _result
	lineageTag: ca06f291-9777-45b7-8da5-70422cda957e

function _latestBackupIsOldBackgroundColor = ```
