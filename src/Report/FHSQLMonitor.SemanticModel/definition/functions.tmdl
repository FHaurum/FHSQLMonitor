function _isFiltersAppliedFlag =
		() =>
		VAR _page = SELECTEDVALUE ( 'Report pages'[Page] )
		VAR _flag =
		    SWITCH (
		        TRUE (),
		        _page = "Agent jobs configuration", [Is filters applied - Flag - Agent jobs configuration],
		        _page = "Agent jobs performance", [Is filters applied - Flag - Agent jobs performance],
		        _page = "Always On configuration", [Is filters applied - Flag - Always On configuration],
		        _page = "Always On performance", [Is filters applied - Flag - Always On performance],
		        _page = "Backup", [Is filters applied - Flag - Backup],
		        _page = "Blocks and deadlocks", [Is filters applied - Flag - Blocks and deadlocks],
		        _page = "Connections", [Is filters applied - Flag - Connections],
		        _page = "CPU", [Is filters applied - Flag - CPU],
		        _page = "Database configuration", [Is filters applied - Flag - Database configuration],
		        _page = "Database IO", [Is filters applied - Flag - Database IO],
		        _page = "Database size", [Is filters applied - Flag - Database size],
		        _page = "Index configuration", [Is filters applied - Flag - Index configuration],
		        _page = "Index leaf statistics", [Is filters applied - Flag - Index leaf statistics],
		        _page = "Index optimize", [Is filters applied - Flag - Index optimize],
		        _page = "Index physical", [Is filters applied - Flag - Index physical],
		        _page = "Index usage", [Is filters applied - Flag - Index usage],
		        _page = "Instance status", [Is filters applied - Flag - Instance status],
		        _page = "Lock statistics", [Is filters applied - Flag - Lock statistics],
		        _page = "Log shipping configuration", [Is filters applied - Flag - Log shipping configuration],
		        _page = "Log shipping status", [Is filters applied - Flag - Log shipping status],
		        _page = "Memory", [Is filters applied - Flag - Memory],
		        _page = "Missing indexes", [Is filters applied - Flag - Missing indexes],
		        _page = "Monitor status", [Is filters applied - Flag - Monitor status],
		        _page = "Ola Hallengren errors", [Is filters applied - Flag - OH errors],
		        _page = "Partitioned indexes", [Is filters applied - Flag - Partitioned indexes],
		        _page = "Performance statistics", [Is filters applied - Flag - Performance statistics],
		        _page = "Plan cache usage", [Is filters applied - Flag - Plan cache usage],
		        _page = "Plan guides", [Is filters applied - Flag - Plan guides],
		        _page = "Query statistics", [Is filters applied - Flag - Query statistics],
		        _page = "Resource Governor", [Is filters applied - Flag - Resource Governor],
		        _page = "Statistics", [Is filters applied - Flag - Statistics],
		        _page = "Stored procedures", [Is filters applied - Flag - Stored procedures - Query statistics],
		        _page = "Table size", [Is filters applied - Flag - Table size],
		        _page = "Triggers", [Is filters applied - Flag - Triggers],
		        _page = "Wait statistics", [Is filters applied - Flag - Wait statistics],
		        BLANK ()
		    )
		VAR _result = _flag
		RETURN _result
	lineageTag: 5efd8dfd-e9a4-4762-985a-aabf60adecc7

