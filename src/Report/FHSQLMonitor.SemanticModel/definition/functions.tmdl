function _isFiltersAppliedBackgroundColor = ```
		() => 
		VAR _page = SELECTEDVALUE ( 'Report pages'[Page] )
		VAR _flag = _isFiltersAppliedFlag ()
		VAR _color =
		    SWITCH (
		        TRUE (),
		        _flag = 0, _standardFillColor (),
		        _flag = 1, _filterInfoCardWithFilterBackgroundColor (),
		        BLANK ()
		    )
		VAR _result = _color
		RETURN _result
		```
	lineageTag: 38b57ac6-39bf-4a88-828c-90c2dfd74a4a

