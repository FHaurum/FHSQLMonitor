table 'Memory clerk type'
	lineageTag: 7317bd22-e769-4251-9699-c1635dd1551b

	column Type
		dataType: string
		lineageTag: ae9e788a-ac7c-4286-b742-ddd9c29f4394
		summarizeBy: none
		sourceColumn: Type

